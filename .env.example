# Elastic Cloud
ELASTIC_ENDPOINT=https://your-cluster.es.region.elastic.cloud
ELASTIC_API_KEY=your_elastic_api_key

# Kibana Agent Builder
KIBANA_ENDPOINT=https://your-cluster.kb.region.elastic.cloud
KIBANA_API_KEY=your_kibana_api_key

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Optional: Elastic Inference endpoint (Claude hosted on Elastic)
ELASTIC_INFERENCE_ID=.anthropic-claude-4.5-sonnet-completion

# Microsoft Teams Channel Bot (optional — @mention bot in Teams channels)
# Create an Azure Bot at https://portal.azure.com and register an Entra App
MICROSOFT_APP_ID=your-azure-bot-app-id
MICROSOFT_APP_PASSWORD=your-azure-bot-client-secret

# Recall.ai Live Meeting Bot (optional — joins Teams calls and listens in real-time)
# Get your API key at https://us-east-1.recall.ai/dashboard/developers/api-keys
RECALL_API_KEY=your-recall-api-key
RECALL_API_BASE=https://us-east-1.recall.ai/api/v1
